# ═══════════════════════════════════════════════════════════════════════════
# 🤖 IA_CLAUDE-Z: INTELLIGENT ARCHITECTURE DEFINITION
# ═══════════════════════════════════════════════════════════════════════════

IA_VERSION = "1.0.0-CLAUDE-Z"
FRAMEWORK = "NetSecurePro-IA22"
SOVEREIGN = True
BIO_DIGITAL = True


# ═══════════════════════════════════════════════════════════════════════════
# 📊 DATABASE SCHEMA DEFINITION
# ═══════════════════════════════════════════════════════════════════════════

DATABASE_SCHEMA = {
    "name": "IA22-Sovereign-DB",
    "type": "SQLite3",
    "tables": {
        "users": {
            "fields": [
                {"name": "id", "type": "INTEGER", "primary_key": True},
                {"name": "username", "type": "TEXT", "unique": True},
                {"name": "email", "type": "TEXT", "unique": True},
                {"name": "hashed_password", "type": "TEXT"},
                {"name": "is_active", "type": "INTEGER", "default": 1},
                {"name": "created_at", "type": "TIMESTAMP", "default": "CURRENT_TIMESTAMP"},
                {"name": "updated_at", "type": "TIMESTAMP", "default": "CURRENT_TIMESTAMP"},
            ],
            "indexes": ["email", "username"],
            "description": "Utilisateurs du système IA22"
        },
        "audit_logs": {
            "fields": [
                {"name": "id", "type": "INTEGER", "primary_key": True},
                {"name": "action", "type": "TEXT"},
                {"name": "user_id", "type": "INTEGER", "foreign_key": "users.id"},
                {"name": "details", "type": "TEXT"},
                {"name": "created_at", "type": "TIMESTAMP", "default": "CURRENT_TIMESTAMP"},
            ],
            "indexes": ["user_id", "created_at"],
            "description": "Logs d'audit des actions"
        },
        "api_keys": {
            "fields": [
                {"name": "id", "type": "INTEGER", "primary_key": True},
                {"name": "user_id", "type": "INTEGER", "foreign_key": "users.id", "not_null": True},
                {"name": "key_hash", "type": "TEXT", "unique": True},
                {"name": "name", "type": "TEXT"},
                {"name": "is_active", "type": "INTEGER", "default": 1},
                {"name": "last_used", "type": "TIMESTAMP"},
                {"name": "created_at", "type": "TIMESTAMP", "default": "CURRENT_TIMESTAMP"},
                {"name": "expired_at", "type": "TIMESTAMP"},
            ],
            "indexes": ["user_id", "key_hash"],
            "description": "Clés API sécurisées"
        },
        "sessions": {
            "fields": [
                {"name": "id", "type": "INTEGER", "primary_key": True},
                {"name": "user_id", "type": "INTEGER", "foreign_key": "users.id", "not_null": True},
                {"name": "token_hash", "type": "TEXT", "unique": True},
                {"name": "user_agent", "type": "TEXT"},
                {"name": "ip_address", "type": "TEXT"},
                {"name": "is_active", "type": "INTEGER", "default": 1},
                {"name": "created_at", "type": "TIMESTAMP", "default": "CURRENT_TIMESTAMP"},
                {"name": "expires_at", "type": "TIMESTAMP"},
            ],
            "indexes": ["user_id", "token_hash"],
            "description": "Sessions utilisateur sécurisées"
        },
        "system_logs": {
            "fields": [
                {"name": "id", "type": "INTEGER", "primary_key": True},
                {"name": "level", "type": "TEXT"},
                {"name": "message", "type": "TEXT"},
                {"name": "module", "type": "TEXT"},
                {"name": "created_at", "type": "TIMESTAMP", "default": "CURRENT_TIMESTAMP"},
            ],
            "indexes": ["level", "created_at"],
            "description": "Logs système IA22"
        },
        "ia22_events": {
            "fields": [
                {"name": "id", "type": "INTEGER", "primary_key": True},
                {"name": "event_type", "type": "TEXT"},
                {"name": "event_data", "type": "TEXT"},
                {"name": "user_id", "type": "INTEGER", "foreign_key": "users.id"},
                {"name": "created_at", "type": "TIMESTAMP", "default": "CURRENT_TIMESTAMP"},
            ],
            "indexes": ["event_type", "created_at"],
            "description": "Événements IA22 du système"
        }
    }
}


# ═══════════════════════════════════════════════════════════════════════════
# 🏗️ ARCHITECTURE MODULES
# ═══════════════════════════════════════════════════════════════════════════

ARCHITECTURE = {
    "core": {
        "module": "ia22.core",
        "class": "IA22Core",
        "description": "Cœur du système IA22",
        "methods": ["process", "health_check"]
    },
    "api": {
        "module": "ia22.api",
        "app": "FastAPI",
        "routes": {
            "system": "GET /health, GET /matrix, GET /system-info",
            "users": "POST /api/users, GET /api/users, GET /api/users/{id}",
            "docs": "GET /docs (Swagger), GET /redoc (ReDoc)"
        }
    },
    "database": {
        "module": "ia22.sqlite_manager",
        "class": "SQLite3Manager",
        "features": ["CRUD", "Query Builder", "Bulk Operations", "Backup/Restore"]
    },
    "security": {
        "module": "ia22.security",
        "auth": "JWT + Bcrypt",
        "encryption": "RSA + AES",
        "features": ["Token Management", "Password Hashing", "API Keys"]
    },
    "communications": {
        "module": "ia22.communications",
        "type": "Messenger",
        "protocol": "Secure Channel"
    },
    "sentinel": {
        "module": "ia22.sentinel",
        "class": "AutoCleaner",
        "retention_days": 30,
        "features": ["Log Cleanup", "Temp File Cleanup"]
    }
}


# ═══════════════════════════════════════════════════════════════════════════
# 🔐 SECURITY PROTOCOLS
# ═══════════════════════════════════════════════════════════════════════════

SECURITY_PROTOCOLS = {
    "authentication": {
        "type": "JWT",
        "algorithm": "HS256",
        "expiration_minutes": 30,
        "refresh_enabled": True
    },
    "password": {
        "algorithm": "bcrypt",
        "min_length": 8,
        "require_uppercase": True,
        "require_lowercase": True,
        "require_numbers": True,
        "require_special": True
    },
    "encryption": {
        "algorithm": "AES-256-GCM",
        "key_derivation": "PBKDF2",
        "iterations": 100000
    },
    "api_keys": {
        "format": "Bearer",
        "rotation_days": 90,
        "max_per_user": 5
    }
}


# ═══════════════════════════════════════════════════════════════════════════
# 📈 PERFORMANCE OPTIMIZATION
# ═══════════════════════════════════════════════════════════════════════════

PERFORMANCE = {
    "database": {
        "journal_mode": "WAL",
        "cache_size": 10000,
        "synchronous": "NORMAL",
        "foreign_keys": True
    },
    "caching": {
        "enabled": True,
        "backend": "Redis",
        "ttl_seconds": 300,
        "key_prefix": "ia22:"
    },
    "connection_pool": {
        "size": 5,
        "max_overflow": 10,
        "timeout": 30
    }
}


