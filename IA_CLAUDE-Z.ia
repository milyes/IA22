DEPLOYMENT = {
    "docker": {
        "enabled": True,
        "base_image": "python:3.12-slim",
        "compose": "docker-compose.yml",
        "services": ["app", "postgres", "redis", "pgadmin"]
    },
    "environment": {
        "development": {
            "debug": True,
